# Use lightweight Node image
FROM node:20-alpine

# Create app directory
WORKDIR /usr/src/app

# Copy package files first (better Docker cache)
COPY package*.json ./

# Install dependencies
RUN npm install --production

# Copy application source
COPY . .

# Environment
ENV NODE_ENV=production

# Expose backend port
EXPOSE 5000

# Start server
CMD ["node", "server.js"]